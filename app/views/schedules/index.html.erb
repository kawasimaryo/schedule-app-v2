<h1 class="mb-4">予定一覧</h1>

<p>本日: <%= Time.current.strftime("%Y/%m/%d") %></p>
<p>予定合計数: <%= @schedules.count %></p>

<table class="table table-striped table-hover">
  <thead class="table-dark">
    <tr>
      <th>ID</th>
      <th>タイトル</th>
      <th>開始日</th>
      <th>終了日</th>
      <th>終日</th>
      <th>更新日時</th>
      <th colspan="3">操作</th>
    </tr>
  </thead>

  <tbody>
    <% @schedules.each do |schedule| %>
      <tr>
        <td><%= schedule.id %></td>
        <td><%= schedule.title %></td>
        <td><%= schedule.start_time.strftime("%Y/%m/%d") %></td>
        <td><%= schedule.end_time.strftime("%Y/%m/%d") %></td>
        <td>
          <%= schedule.all_day? ? '○' : '' %>
        </td>
        <td><%= schedule.updated_at.strftime("%Y/%m/%d %H:%M") %></td>
        <td>
          <%= link_to '詳細', schedule, class: 'btn btn-sm btn-primary' %>
        </td>
        <td>
          <%= link_to '編集', edit_schedule_path(schedule), class: 'btn btn-sm btn-warning' %>
        </td>
        <td>
          <%= link_to '削除', '#',
              class: 'btn btn-sm btn-danger',
              data: {
                bs_toggle: 'modal',
                bs_target: '#deleteModal',
                'delete-url': schedule_path(schedule)
              } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<p>
  <%= link_to '新規作成', new_schedule_path, class: 'btn btn-success' %>
</p>

<!-- 🗑️ 削除確認モーダル（強化版） -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-danger">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title" id="deleteModalLabel">
          <i class="bi bi-exclamation-triangle-fill me-2"></i> 本当に削除しますか？
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="閉じる"></button>
      </div>
      <div class="modal-body">
        <p>この予定は削除すると元に戻せません。<br>
        本当に削除してよろしいですか？</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
          キャンセル
        </button>

        <form id="delete-form" method="post" action="">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <input type="hidden" name="_method" value="delete">
          <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash-fill me-1"></i> 削除する
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

